#!/bin/sh
# Initramfs hook: add oled_early binary for early boot display
PREREQ=""
prereqs() { echo "$PREREQ"; }
case "$1" in prereqs) prereqs; exit 0 ;; esac
. /usr/share/initramfs-tools/hook-functions

# Default assumes user `pi` and clone target ~/pi-dmx-controller-v2 (adjust before install-oled-initramfs if yours differs)
BINARY="/home/pi/pi-dmx-controller-v2/utils/oled_early"
if [ -f "$BINARY" ]; then
    copy_exec "$BINARY" /bin/oled_early
else
    echo "oled-boot hook: $BINARY not found, skipping"
fi
