[Unit]
Description=OLED splash (Loading...) before DMX app
# Run as soon as root is mounted - no oled_wake (initramfs handles early display)
After=local-fs.target
Before=multi-user.target

[Service]
Type=oneshot
# Run as same user as dmx (adjust User/WorkingDirectory to match your install)
User=benglasser
WorkingDirectory=/home/benglasser/pi-dmx-controller-v2
ExecStart=/home/benglasser/pi-dmx-controller-v2/.venv/bin/python /home/benglasser/pi-dmx-controller-v2/oled_boot.py
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
