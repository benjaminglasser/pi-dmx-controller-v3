#!/bin/bash
# Toggle pi-dmx.service autostart (systemd). Use while troubleshooting DMX/hardware.

set -euo pipefail

case "${1:-}" in
  disable|off)
    sudo systemctl stop pi-dmx.service 2>/dev/null || true
    sudo systemctl disable pi-dmx.service
    echo "pi-dmx.service stopped and disabled — it will NOT start on boot."
    echo "Re-enable with: ./scripts/dmx-dev enable"
    ;;
  enable|on)
    sudo systemctl enable pi-dmx.service
    sudo systemctl start pi-dmx.service
    echo "pi-dmx.service enabled and started."
    ;;
  status)
    echo "Autostart (enabled = starts on boot):"
    systemctl is-enabled pi-dmx.service 2>/dev/null || true
    echo ""
    echo "Running now:"
    systemctl is-active pi-dmx.service 2>/dev/null || echo "inactive"
    ;;
  *)
    echo "Usage: ./scripts/dmx-dev {disable|enable|status}"
    echo ""
    echo "  disable, off  - Stop service and disable autostart (for DMX troubleshooting)"
    echo "  enable, on    - Enable autostart and start the service"
    echo "  status        - Show enabled/active state"
    exit 1
    ;;
esac
